# Midday Engine — static analysis gate (pinned clang-tidy via scripts/verify.sh).
# Philosophy: high-signal checks as hard errors; noisy style checks stay off — formatting
# is clang-format's job, naming is the reviewer's job.
# EnumCastOutOfRange is off: analyzer path diagnostics ignore the header exclude filter
# and fire on vendored fast_float's standard enum-bitmask idiom; the UBSan CI lane covers
# genuine out-of-range enum casts at runtime (D-BUILD-016).
# use-designated-initializers is off: positional {x, y, z} literals are the domain
# convention for math aggregates (Vec/Quat/Mat columns — as in GLM/Godot/DirectXMath);
# designating every component would bury core/math in noise. Field-heavy config structs
# still SHOULD designate (reviewer's job, per the philosophy above). (D-BUILD-018)
Checks: >
  bugprone-*,
  performance-*,
  modernize-*,
  cppcoreguidelines-slicing,
  cppcoreguidelines-special-member-functions,
  misc-definitions-in-headers,
  misc-unused-using-decls,
  readability-container-size-empty,
  readability-redundant-smartptr-get,
  readability-static-definition-in-anonymous-namespace,
  -bugprone-easily-swappable-parameters,
  -modernize-use-designated-initializers,
  -modernize-use-trailing-return-type,
  -modernize-avoid-c-arrays,
  -performance-avoid-endl,
  -clang-analyzer-optin.core.EnumCastOutOfRange
WarningsAsErrors: '*'
# LLVM regex has no negative lookahead; the include/exclude pair below is the
# supported way (clang-tidy 19+) to lint first-party headers while keeping
# vendored/system code out of the gate.
HeaderFilterRegex: '.*'
ExcludeHeaderFilterRegex: '.*(third_party|build|\.venv-tools)/.*'
FormatStyle: file
