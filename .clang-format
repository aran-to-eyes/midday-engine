# Midday Engine — canonical formatting (enforced by scripts/verify.sh with a PINNED
# clang-format from .venv-tools; do not run other clang-format versions against the tree).
BasedOnStyle: LLVM
Standard: c++20
ColumnLimit: 100
IndentWidth: 4
AccessModifierOffset: -4
PointerAlignment: Left
DerivePointerAlignment: false
AllowShortFunctionsOnASingleLine: Inline
AllowShortLambdasOnASingleLine: All
BinPackArguments: false
BinPackParameters: false
BreakBeforeBraces: Attach
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^"'
    Priority: 1
  - Regex: '^<(doctest|quickjs|Jolt|vulkan|Metal)/'
    Priority: 3
  - Regex: '^<'
    Priority: 2
SeparateDefinitionBlocks: Always
InsertNewlineAtEOF: true
